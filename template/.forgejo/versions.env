# Single source of truth for CI tool versions. Both admit.yml (which VERIFIES a
# signature) and deploy.yml (which CREATES it) load COSIGN_VERSION from here via
#   grep -E '^[A-Z_]+=' .forgejo/versions.env >> "$GITHUB_ENV"
# so the signer and the verifier can never drift — a v2 cosign cannot verify a
# v3-produced signature, which silently fails the admission supply-chain check.
COSIGN_VERSION=v3.1.1
CONFTEST_VERSION=0.68.2
SYFT_VERSION=1.46.0
ORAS_VERSION=1.2.0
