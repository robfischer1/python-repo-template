# Forgejo Actions: build + deploy on push to main (constellation core_backed star).
# Runs on the nas01 self-hosted runner (label `nas01`) with the host docker
# socket mounted, so `docker compose up -d --build` targets nas01's own daemon.
#
# Builds FROM mnemosyne-core-base (the private schema is baked in; mnemosyne-core
# comes from the public git pin in uv.lock) -- no sibling clones, no private-repo
# auth in this deploy.
#
# REQUIRED Forgejo Actions secret (repo -> Settings -> Actions -> Secrets):
#   DATABASE_URL  the corpus connection string the live container uses.
#
# Prereqs: Forgejo Actions enabled on the repo + a runner with the `nas01` label
# (host-networked, /var/run/docker.sock allowed).

name: deploy
on:
  push:
    branches: [main]
    paths-ignore:
      - "**.md"
      - "docs/**"
      - "LICENSE"

jobs:
  build-and-deploy:
    runs-on: nas01
    container:
      image: catthehacker/ubuntu:act-22.04   # glibc + docker CLI + compose v2
      volumes:
        - /var/run/docker.sock:/var/run/docker.sock
    steps:
      - uses: https://github.com/actions/checkout@v4

      # Install uv via its official script rather than astral-sh/setup-uv:
      # that action resolves releases through GITHUB_API_URL, which on Forgejo
      # points at this instance (no `astral-sh` user) and 403/404s.
      - name: Install uv
        env:
          UV_INSTALL_DIR: /usr/local/bin
        run: curl -LsSf https://astral.sh/uv/install.sh | sh

      - name: Gate — lint / type / test (deploy only on green)
        run: |
          uv sync --all-extras
          uv run pre-commit run --all-files --show-diff-on-failure
          uv run mypy src tests
          uv run pyright
          uv run pytest -q

      # Security scanners (template v0.3.0). pip-audit BLOCKS on a dependency CVE.
      # opengrep runs the vendored taint ruleset (rules/sast), a BLOCKING gate while
      # tuned. LANG forces UTF-8 — opengrep reads files under the runner's C locale
      # otherwise and dies on any non-ASCII byte.
      - name: Dependency vuln scan (pip-audit)
        run: uv run --with pip-audit pip-audit

      - name: SAST (opengrep, scoped taint rules)
        run: |
          curl -fsSL https://raw.githubusercontent.com/opengrep/opengrep/main/install.sh | bash
          export PATH="$HOME/.opengrep/cli/latest:$PATH"
          export LANG=C.UTF-8 LC_ALL=C.UTF-8
          opengrep scan --config rules/sast --error .

      # Build the image, scan it, then deploy. Trivy BLOCKS the deploy on a
      # FIXABLE HIGH/CRITICAL image CVE; --ignore-unfixed drops base-image CVEs
      # with no released fix (not actionable here — slim the base image for those).
      # The image name is read from the compose file, so this stays generic across
      # stamped repos. compose needs DATABASE_URL set (the `${DATABASE_URL:?}`
      # guard is evaluated at config-parse time, even for build/config).
      - name: Build image
        env:
          DATABASE_URL: ${{ secrets.DATABASE_URL }}
        run: docker compose build

      - name: Image CVE scan (Trivy)
        env:
          DATABASE_URL: ${{ secrets.DATABASE_URL }}
        run: |
          IMG=$(docker compose config --images | head -1)
          echo "scanning image: $IMG"
          docker run --rm \
            -v /var/run/docker.sock:/var/run/docker.sock \
            aquasec/trivy:latest image \
            --severity HIGH,CRITICAL --ignore-unfixed --exit-code 1 --no-progress \
            "$IMG"

      - name: Deploy on nas01
        env:
          DATABASE_URL: ${{ secrets.DATABASE_URL }}
        run: docker compose up -d
