{%- if core_backed %}
# Per-service Docker Compose stack for {{ service_name }} (nas01, constellation star).
#
# INTERIM (until the Hades gateway / MP-B lands): joins mnemosyne-net AND stays
# on the project default network with its host port published, so consumers keep
# reaching it. When MP-B is live, drop `ports:` + the `default` network entry
# -> internal-only (reachable only via the edge).
services:
  {{ service_name }}:
    image: ghcr.io/robfischer1/{{ service_name }}:latest
    build: .
    environment:
      PORT: "{{ port }}"
      HOST: "0.0.0.0"
      DATABASE_URL: "${DATABASE_URL:?DATABASE_URL is required (corpus phdb)}"
      MNEMOSYNE_SCHEMA_DIR: "/app/schema"
      MNEMOSYNE_DB_ROLE: "{{ package_name }}"
    ports:
      - "{{ port }}:{{ port }}"
    networks:
      - default
      - mnemosyne-net
    restart: unless-stopped

networks:
  default:
  mnemosyne-net:
    external: true
{%- else %}
# Per-service Docker Compose stack for {{ service_name }} (nas01).
# State (if any) externalizes to a named volume or the nas01 Postgres by URL —
# add a `volumes:` mount and a DATABASE_URL env when the service becomes stateful.
services:
  {{ service_name }}:
    image: ghcr.io/robfischer1/{{ service_name }}:latest
    build: .
    environment:
      PORT: "{{ port }}"
      HOST: "0.0.0.0"
    ports:
      - "{{ port }}:{{ port }}"
    restart: unless-stopped
{%- endif %}
