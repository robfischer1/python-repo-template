[project]
name = "{{ service_name }}"
dynamic = ["version"]
description = "{{ description }}"
requires-python = ">=3.12"
license = "Apache-2.0"
authors = [{ name = "{{ author_name }}" }]
classifiers = [
    "Development Status :: 3 - Alpha",
    "Programming Language :: Python :: 3.12",
    "Operating System :: OS Independent",
]
dependencies = [
    "pydantic-settings>=2.0",
    # The op-contract ({live, ready, metrics}), the Nyx admission client, and the
    # Hemera OTLP helper come from the stellar_core SDK — pre-baked into the
    # stellar_core base image (warm builds), resolved from the Forgejo PyPI for
    # local dev. The CI admission gate is still a CI-time tool pulled ephemerally
    # by .forgejo/workflows/admit.yml, not a project dependency.
    "stellar-core>=1.0.2",
{%- if mcp %}
    # Pinned to a minor: mcp's transport-security defaults (DNS-rebinding) shift
    # across minors, and an unpinned floor let stars stamped days apart resolve
    # different versions. Renovate bumps this; server.py configures allowed_hosts.
    "mcp[cli]~=1.28.1",
{%- endif %}
{%- if core_backed %}
    "mnemosyne-core>=0.2.0",
{%- endif %}
]

[project.urls]
Repository = "https://github.com/robfischer1/{{ service_name }}"
{%- if mcp %}

[project.scripts]
{{ service_name }} = "{{ package_name }}.server:main"
{%- endif %}

[project.optional-dependencies]
dev = [
    "pytest>=8",
    "pytest-cov>=5",
    "ruff==0.15.16",
    "mypy>=1.10",
    "pyright==1.1.410",
    "pre-commit>=3.5",
]
{%- if mcp %}
# Heartbeat publisher (the `kafka` extra): confluent-kafka backs the Producer
# that ships {live,ready,metrics} to Pontus. Optional — a star without it just
# doesn't beat (the MCP server still serves). Image installs it via
# `uv sync --extra kafka` (see the Dockerfile).
kafka = ["confluent-kafka>=2.0"]
{%- endif %}
{%- if sovereign_database %}
# Sovereign Postgres driver, installed into the image via `uv sync --extra pg`
# (see the Dockerfile). Kept an extra, not a base dep, so non-DB stars stay lean.
pg = [
    "psycopg[binary]>=3.1",
{%- if db_kind == "pgvector" %}
    "pgvector>=0.3",
{%- endif %}
]
{%- endif %}

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

# Single-source the version: hatch reads `__version__` from the package, so
# pyproject and the package never drift. Bump the literal in __init__.py only.
[tool.hatch.version]
path = "src/{{ package_name }}/__init__.py"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

# Lint / type / test baseline — the canonical Forge policy
# (furnace/source/templates/pyproject.toml; furnace code-standards block).
[tool.ruff]
target-version = "py312"
line-length = 80

[tool.ruff.lint]
select = ["ALL"]
ignore = [
    "COM", "ISC", "Q", "E501",
    "D203", "D213",
    "ANN001", "ANN002", "ANN003", "ANN202", "ANN204", "ANN401",
    "EM", "TRY003",
    "C901", "PLR09", "PLR2004",
    "T201", "PLC0415", "FBT", "SLF001",
    "PLW0603", "TRY300", "TRY301", "ARG002",
    "PERF401", "PERF403", "A002", "EXE",
]

[tool.ruff.lint.per-file-ignores]
"tests/**" = ["S", "PT", "ANN", "D", "ARG", "PLR2004", "SLF001", "INP001", "ERA001", "E402", "PLW1510"]

[tool.mypy]
python_version = "3.12"
strict = true
warn_return_any = true
warn_unused_configs = true
{%- if mcp %}

# confluent-kafka ships no type stubs (the optional `kafka` extra; absent in the
# CI gate env entirely). heartbeat.py lazy-imports it — ignore the missing stubs.
[[tool.mypy.overrides]]
module = ["confluent_kafka.*"]
ignore_missing_imports = true
{%- endif %}

[[tool.mypy.overrides]]
module = ["tests.*"]
disallow_untyped_defs = false
disallow_untyped_calls = false
disallow_incomplete_defs = false
check_untyped_defs = false
warn_return_any = false

[tool.pyright]
include = ["src", "tests"]
exclude = ["**/__pycache__", ".venv"]
typeCheckingMode = "strict"
pythonVersion = "3.12"
venvPath = "."
venv = ".venv"
reportUnnecessaryTypeIgnoreComment = false
reportUnknownMemberType = false
reportUnknownArgumentType = false
reportUnknownVariableType = false
reportUnknownParameterType = false
reportMissingTypeStubs = false

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src"]
# Coverage is measured every run; `term-missing` lists untested lines. Ratchet a
# floor up as real tests land by appending to addopts, e.g. `--cov-fail-under=70`.
addopts = "--cov={{ package_name }} --cov-report=term-missing"

[tool.coverage.run]
source = ["src"]
branch = true

# The stellar_core SDK lives on the Forgejo PyPI. The base image bakes it in, so
# the Docker build resolves it offline; this index is for local dev + lock gen.
[[tool.uv.index]]
name = "forgejo"
url = "https://forgejo.notusmi.com/api/packages/rob/pypi/simple/"

[tool.uv.sources]
stellar-core = { index = "forgejo" }
{%- if core_backed %}
# Core is the public git pin (the #1300 standard); the base image bakes the
# private schema. For local co-dev against an adjacent checkout, override with
# `uv pip install -e ../mnemosyne_core` after `uv sync`.
mnemosyne-core = { git = "https://github.com/robfischer1/mnemosyne_core.git", tag = "{{ core_version }}" }
{%- endif %}
