# star.toml — generated by copier from your answers.
# The conformance target every constellation gate reads.
# Canonical schema: constellation.manifest.StarManifest (pydantic).
# Validate locally with: uv run --with git+https://forgejo.notusmi.com/rob/constellation.git python -c "from constellation.manifest import parse_file; parse_file('star.toml')"
name    = "{{ service_name }}"
service = "{{ project_name }}"
cluster = "{{ cluster }}"
charter = "{{ charter }}"

[substrate]
kind      = "{{ substrate_kind }}"
namespace = "{{ star_namespace }}"

[logic]
entrypoint = "{% if mcp %}{{ package_name }}.server:main{% else %}{{ package_name }}:main{% endif %}"

[interface]
# Reachability invariant: len(sync) + len(async) >= 1.
# {% if mcp %}MCP stars are reachable via their tool surface (streamable-HTTP).{% else %}Library/CLI stars expose a console entrypoint.{% endif %}
sync  = ["{% if mcp %}mcp{% else %}cli{% endif %}"]
async = [{% if interstellar %}"kafka"{% endif %}]

# Governance pin — the cosign-signed policy bundle this star subscribes to (F7).
# Renovate bumps `tag` + `digest` when a new bundle publishes (see renovate.json).
[governance]
bundle = "oci://forgejo.notusmi.com/furnace/policy"
tag    = "policy-v1"
digest = "sha256:9f86d081884c7d659a2feaa0c55ad015a3bf4f1b2b0b822cd15d6c15b0f00a08"

absorbs = []
