"""constellation.ops -- Universal operational contract library.

Defines and enforces the {live, ready, metrics} contract across three transport
adapters so that every star is reachable for health regardless of its native
transport:

  HTTP stars    -- HttpOpsAdapter exposes /livez  /readyz  /metrics (z-pages).
  MCP stars     -- McpOpsAdapter exposes an ops_introspect() tool.
  Async workers -- AsyncHeartbeatPublisher publishes to *._ops.heartbeat topic.

All surfaces are tailnet-only (documented; the library does not bind ports).
The redact() helper masks pydantic SecretStr fields for safe configz dumps.
"""
from __future__ import annotations

from datetime import UTC, datetime
from typing import TYPE_CHECKING, Any, Protocol

if TYPE_CHECKING:
    from collections.abc import Callable

from pydantic import BaseModel, SecretStr

# ---------------------------------------------------------------------------
# HealthState -- the universal operational contract value object
# ---------------------------------------------------------------------------

MetricValue = float | int | str


class HealthState(BaseModel):
    """The {live, ready, metrics} contract value object shared by all adapters."""

    live: bool
    ready: bool
    metrics: dict[str, MetricValue] = {}

    model_config = {'frozen': True}


# ---------------------------------------------------------------------------
# OpsAdapter protocol -- structural; adapters need not inherit
# ---------------------------------------------------------------------------


class OpsAdapter(Protocol):
    """Structural protocol satisfied by all concrete ops adapters."""

    def health(self) -> HealthState:
        """Return the current HealthState."""
        ...


# ---------------------------------------------------------------------------
# HTTP response value object (framework-free)
# ---------------------------------------------------------------------------


class HttpOpsResponse(BaseModel):
    """Framework-free HTTP response wrapper returned by z-page methods."""

    status_code: int
    body: str | dict[str, Any]
    content_type: str

    model_config = {'frozen': True}
# ---------------------------------------------------------------------------
# HttpOpsAdapter -- /livez  /readyz  /metrics
# ---------------------------------------------------------------------------


class HttpOpsAdapter:
    """Renders HealthState into HTTP responses for /livez, /readyz, /metrics."""

    def __init__(self, state: HealthState) -> None:
        """Initialise adapter with the star operational state."""
        self._state = state

    def health(self) -> HealthState:
        """Return the current HealthState."""
        return self._state

    def live_response(self) -> HttpOpsResponse:
        """Return /livez response: 200 if live, 503 otherwise."""
        if self._state.live:
            return HttpOpsResponse(
                status_code=200,
                body={'status': 'ok'},
                content_type='application/json',
            )
        return HttpOpsResponse(
            status_code=503,
            body={'status': 'not_live'},
            content_type='application/json',
        )

    def ready_response(self) -> HttpOpsResponse:
        """Return /readyz response: 200 if ready, 503 otherwise."""
        if self._state.ready:
            return HttpOpsResponse(
                status_code=200,
                body={'status': 'ok'},
                content_type='application/json',
            )
        return HttpOpsResponse(
            status_code=503,
            body={'status': 'not_ready'},
            content_type='application/json',
        )

    def metrics_response(self) -> HttpOpsResponse:
        """Return /metrics as text/plain Prometheus one-line-per-key format."""
        lines: list[str] = []
        for key, val in self._state.metrics.items():
            lines.append(f'# TYPE {key} gauge')
            lines.append(f'{key} {val}')
        body = '\n'.join(lines) + ('\n' if lines else '')
        return HttpOpsResponse(
            status_code=200,
            body=body,
            content_type='text/plain',
        )


# ---------------------------------------------------------------------------
# McpOpsAdapter -- introspect() tool for MCP stars
# ---------------------------------------------------------------------------


class McpOpsAdapter:
    """Serialises HealthState as a JSON-safe dict for MCP introspection."""

    def __init__(self, state: HealthState) -> None:
        """Initialise adapter with the star operational state."""
        self._state = state

    def health(self) -> HealthState:
        """Return the current HealthState."""
        return self._state

    def introspect(self) -> dict[str, Any]:
        """Return {live, ready, metrics} as a JSON-serialisable dict."""
        return {
            'live': self._state.live,
            'ready': self._state.ready,
            'metrics': dict(self._state.metrics),
        }
# ---------------------------------------------------------------------------
# AsyncHeartbeatPublisher -- *._ops.heartbeat topic
# ---------------------------------------------------------------------------


class AsyncHeartbeatPublisher:
    """Publishes HealthState to *._ops.heartbeat for async-only stars."""

    def __init__(
        self,
        star_name: str,
        publish: Callable[[str, dict[str, Any]], None],
        topic: str | None = None,
    ) -> None:
        """Initialise publisher.

        Args:
            star_name: Name of the star (used as topic prefix and payload field).
            publish: Callable(topic, payload) that delivers the message.
            topic: Override the default topic; default is {star_name}._ops.heartbeat.

        """
        self._star_name = star_name
        self._publish = publish
        self._topic = topic if topic is not None else f'{star_name}._ops.heartbeat'

    def publish(self, state: HealthState) -> None:
        """Publish a heartbeat payload containing {star, live, ready, metrics, ts}."""
        payload: dict[str, Any] = {
            'star': self._star_name,
            'live': state.live,
            'ready': state.ready,
            'metrics': dict(state.metrics),
            'ts': datetime.now(UTC).isoformat(),
        }
        self._publish(self._topic, payload)


# ---------------------------------------------------------------------------
# redact() -- SecretStr-safe configz dump
# ---------------------------------------------------------------------------


def _redact_value(v: Any) -> Any:
    if isinstance(v, SecretStr):
        return '**REDACTED**'
    if isinstance(v, dict):
        return {k: _redact_value(vv) for k, vv in v.items()}
    return v


def redact(model: BaseModel) -> dict[str, Any]:
    """Return model.model_dump() with SecretStr values masked as **REDACTED**."""
    raw = model.model_dump()
    return {k: _redact_value(v) for k, v in raw.items()}


__all__ = [
    'AsyncHeartbeatPublisher',
    'HealthState',
    'HttpOpsAdapter',
    'HttpOpsResponse',
    'McpOpsAdapter',
    'MetricValue',
    'OpsAdapter',
    'redact',
]
