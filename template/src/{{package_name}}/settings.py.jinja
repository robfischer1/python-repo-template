"""Typed runtime configuration for {{ service_name }}.

Settings resolve from (lowest to highest precedence): the code defaults below
-> environment variables prefixed `{{ package_name | upper }}_`. Validation runs
at construction, so a malformed value fails fast at startup instead of deep in a
request path. Add fields below; type any secret as `pydantic.SecretStr` so it
never surfaces in logs or repr.
"""

from __future__ import annotations

from functools import lru_cache

from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    """Process configuration, validated from the environment."""

    model_config = SettingsConfigDict(
        env_prefix="{{ package_name | upper }}_",
        extra="ignore",
    )

    log_level: str = "INFO"
    # OTel exporter target — every star ships telemetry to Hemera, the
    # observability plane's OTLP collector, so Nyx can read its standing
    # (see observability.py). stellar_core.otlp_endpoint() is the SDK helper.
    otel_endpoint: str = "http://hemera:4318"
{%- if mcp %}
    host: str = "0.0.0.0"  # noqa: S104 — operator-chosen HTTP bind host
    port: int = {{ port }}
{%- endif %}


@lru_cache
def get_settings() -> Settings:
    """Return the process-wide settings singleton (constructed once)."""
    return Settings()
