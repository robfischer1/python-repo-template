"""Smoke tests for {{ service_name }}."""

import re

from {{ package_name }} import __version__
from {{ package_name }}.health import current_health
from {{ package_name }}.observability import configure_telemetry
from {{ package_name }}.oneiroi import emit_memory
{%- if mcp %}
from {{ package_name }}.server import mcp, ping
{%- endif %}
from {{ package_name }}.settings import get_settings


def test_version() -> None:
    # Assert a valid X.Y.Z version rather than a frozen literal, so the test
    # survives version bumps instead of rotting into a CI break.
    assert re.fullmatch(r"\d+\.\d+\.\d+", __version__)


def test_settings_load() -> None:
    assert get_settings().log_level == "INFO"


def test_health_surface() -> None:
    # Born-with operational contract from constellation.ops.
    state = current_health()
    assert state.live is True
    assert state.ready is True


def test_observability_endpoint() -> None:
    # Born-with OTel wiring resolves the exporter target from settings.
    assert configure_telemetry() == get_settings().otel_endpoint


def test_oneiroi_hook() -> None:
    # Born-with Oneiroi memory hook is a safe no-op until the plane is live.
    assert emit_memory("smoke", {"ok": True}) is None
{%- if mcp %}


def test_ping_tool() -> None:
    assert ping()["status"] == "ok"


def test_server_name() -> None:
    assert mcp.name == "{{ service_name }}"
{%- endif %}
